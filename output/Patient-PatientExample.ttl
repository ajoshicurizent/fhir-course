@prefix fhir: <http://hl7.org/fhir/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# - resource -------------------------------------------------------------------

<http://courses.ajoshi.org/fhir/Patient/PatientExample> a fhir:Patient ;
  fhir:nodeRole fhir:treeRoot ;
  fhir:id [ fhir:v "PatientExample"] ; # 
  fhir:meta [
     fhir:profile ( [
       fhir:v "http://courses.ajoshi.org/fhir/StructureDefinition/MyPatient"^^xsd:anyURI ;
       fhir:l <http://courses.ajoshi.org/fhir/StructureDefinition/MyPatient>
     ] )
  ] ; # 
  fhir:name ( [
     fhir:family [ fhir:v "Pond" ] ;
     fhir:given ( [ fhir:v "James" ] )
  ] ) . # 

# -------------------------------------------------------------------------------------

